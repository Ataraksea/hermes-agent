# Hermes Desktop environment template.
# Copy this file to .env, then run ./setup.sh or docker compose up -d --build.
# Do not commit your real .env file.

# VNC_PASSWORD controls browser-based noVNC login.
# Default: generated by setup.sh. Change when exposing noVNC beyond localhost.
VNC_PASSWORD=change-me

# HERMES_PASSWORD is the Linux password for the hermes user inside the container.
# Default: generated by setup.sh. Change for remote SSH/password usage.
HERMES_PASSWORD=change-me

# VNC_PORT maps the raw VNC server to the host.
# Default: 5901. Change if another VNC service already uses this port.
VNC_PORT=5901

# NOVNC_PORT maps the web noVNC UI to the host.
# Default: 6080. Change if another web service already uses this port.
NOVNC_PORT=6080

# TERMINAL_SSH_PORT maps the container SSH server to the host.
# Default: 2222. Change if 2222 is already in use.
TERMINAL_SSH_PORT=2222

# VNC_RESOLUTION controls the desktop screen size.
# Default: 1920x1080. Lower it for cheaper/faster screenshots on small VPSes.
VNC_RESOLUTION=1920x1080

# AUTHORIZED_KEYS enables passwordless SSH for the hermes user.
# Default: empty. Recommended for automation. Paste one or more public keys.
# AUTHORIZED_KEYS=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA...
AUTHORIZED_KEYS=

# COMPUTER_USE_ENABLED gates the Hermes computer_use tool.
# Default: false in Hermes unless explicitly set. Set true only when you want desktop control.
COMPUTER_USE_ENABLED=true

# COMPUTER_USE_BACKEND selects how tools/computer_use_tool.py reaches the desktop.
# Default: terminal. Use ssh for this docker-compose setup.
COMPUTER_USE_BACKEND=ssh

# COMPUTER_USE_DISPLAY is the X display inside the desktop container.
# Default: :1. Change only if you customize the VNC display number.
COMPUTER_USE_DISPLAY=:1

# COMPUTER_USE_VNC_URL is returned to users so they can watch/take over manually.
# Default: local noVNC URL. Change to your public/VPN URL on a remote server.
COMPUTER_USE_VNC_URL=http://localhost:6080/vnc.html

# TERMINAL_SSH_HOST is where Hermes should SSH for desktop commands.
# Default: localhost when Hermes runs on the same host as docker compose.
TERMINAL_SSH_HOST=localhost

# TERMINAL_SSH_USER is the Linux user inside the desktop container.
# Default: hermes. Change only if you rebuild the image with another user.
TERMINAL_SSH_USER=hermes
